# Banco de dados
HELPDESK_DB_USER=seu_usuario
HELPDESK_DB_PASS=sua_senha

# JWT
HELPDESK_JWT_SECRET=sua_chave_secreta_jwt

# E-mail (envio de credenciais no primeiro acesso)
# Se estiver usando Gmail, HELPDESK_MAIL_PASS deve ser uma "senha de app" (App Password),
# não a senha da sua conta Google. Gere uma em: https://myaccount.google.com/apppasswords
# (requer verificação em duas etapas ativada na conta)
HELPDESK_MAIL_ADDRESS=seu_email@exemplo.com
HELPDESK_MAIL_PASS=sua_senha_de_app
HELPDESK_MAIL_HOST=smtp.gmail.com